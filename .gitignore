.env
__pycache__/
*.pyc
chroma_db/
.venv/
.python-version

# Document corpus — populated by scripts/sourcing/ or by an upstream pipeline.
# Not tracked because PDFs are large, reproducible, and not part of the codebase.
docs/

# Local Claude Code configuration (skills, settings) — per-developer.
.claude/

# Sourcing-script dedup state. Generated by scripts/sourcing/fetch_papers.py;
# each clone starts with an empty manifest and re-fetches.
scripts/sourcing/manifest.json

# Ingestion debug outputs and quarantine. Written only when --debug is set
# or when a document fails QC. Throwaway state; do not commit.
debug/

# Eval run records. Generated by tests/eval/run_eval.py; one record per
# invocation. Local to each developer's runs; not part of the codebase.
tests/eval/results.jsonl
tests/eval/results_*.jsonl
